#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <pthread.h>
#include <semaphore.h>

int grafo [30][30];
int nodosarecorrer[5];
int nodoinicial;


typedef struct {
   int nodoA; //nodo donde uno se encuentra
   int rutasNodo[30]; // rutas maximas que se pueden tomar
   int cantidadPasosR; // cuantos nodos pase
   int visitado[5]; // cuantos  nodos validos tengo, si es 1 es que fue visitado y si es 0 es que no fue visitado
} ruta;


void lee_grafo()
{
  FILE * arch;
  char linea  [160], * p, *q;
  int i=0,j,k;


  arch = fopen("grafo.csv","r");
  while ( fgets(linea,160,arch) != NULL)
  {
      if ( i==0) /* lee primera linea = Nodo inicial */
      {
	 nodoinicial = atoi(linea);
	 printf("nodo inicio  = %d \n", nodoinicial);
         i++;
       }else
	{ 
          linea[strlen(linea)-1]=';';     /* reemplaza el \n por ; para que el strtok tome el ultimo numero */		
	  if (i == 1)  /* Segunda linea = Nodos a recorrer */
          {
	     p = strtok(linea,";");   /* encuento el string anterior a un ; que corresponde al nodo */
             for(j=0;j<5;j++)	
	     {	
		nodosarecorrer[j] = atoi(p);     /* lo almaceno en el vector nodosarecorrer */
	        printf("%d \n",nodosarecorrer[j]);
		p = strtok(NULL,";");        /* busco el sigiente ; en el string */
	     }  
	     i++; 
	  } 
           else   /* Desde tercera linea , por cada nodo  lista  sus enlaces */
           {  
	     p = strtok(linea,";");  /* saco el nodo del string */
             j = atoi(p) - 1;
	     k = 0;
             while ((p =strtok(NULL,";")) != NULL)  /* busco cada nodo apuntado que está separado por ; */
	     {
		 grafo [j][k++]= atoi(p);    /* en la matriz grafo, dejo cada enlace del nodo */
	     }
	     grafo[j][k] = -1;  /* inserto al final de la fila un -1 para indicar que no hay mas enlace */
	   }
	}
  }
 }





void imprime_grafo()
{
   int i, j;
   for (i=0;i<30;i++)
   {
      printf("\n nodo %d -> ",i+1);	   
      for (j=0;grafo[i][j] != -1;j++)
	  printf(" - %d",grafo[i][j]);    

   }
}



//FUNCIONES AUXILIARES 


int validarObjetivo(int nodoActual){// si es 1 es valido y si es 0 es invalido 
    int i =0;
    for (i=0; i<5; i++){
        if (nodoActual == nodosarecorrer[i]){
            return 1;
            
        }
    }
    return -1;
}

void objetivoMarca(int numNodo, ruta *rutaVisitada){ //para marcar un nodo visitado
    int posicion = 0;

    posicion = validarObjetivo(numNodo);
    if (posicion != -1){ // marca el nopdo si es realmente valido o si realmente existe, es -1 porque podria haber un nodo en la posicion 0
        rutaVisitada->visitado[posicion] = 1; //marco el nodo
}
}




ruta rutaOptima(ruta lista[]){ //ruta que se tomara en cuenta
    int comparador = 30; // comparadr para saber cual es la ruta mas optima 
    int i = 0;
    int mejor = -1;
    while (lista[i].cantidadPasosR != -1){ // mientras la cantidad de pasos sea menor a 30, se seguira comparando
    if (lista[i].cantidadPasosR <= comparador){
            comparador = lista[i].cantidadPasosR;
            mejor = i;   // si la cantidad de pasos es menor a la del comparador, se actualiza el comparador

    }
    i++;
    }
    return lista[mejor];

}

int nodosCompletados(ruta *lista){ //validar que se hayan validado los 5
    int i = 0;
    for ( i = 0; i < 5; i++){
        if (lista->visitado[i] == 0){
            return 0;
        }
    }
    return 1;
}
 

int validarCamino (ruta *lista, int nodoLlegar){ // validar que el nodo se conecte con el siguiente 
    int fila = lista->nodoA - 1;
    int i = 0;

    for ( i=0; grafo[fila][i] != -1; i++){
        if (grafo[fila][i] == nodoLlegar){
            return 1;
        }
    }
    return 0;
}








