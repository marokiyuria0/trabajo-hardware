//--------------------RECORRIDOS--------------------------------



void recorridoGrafo(ruta *rutaActual){
    int i = 0;
    if(rutaActual == NULL){
        return ;
    }

    rutaActual->rutasNodo[rutaActual->cantidadPasosR] = rutaActual->nodoA; 
     
    
    if (validadorObjetivosCompletados(rutaActual) == 1){ // si ya se tienen todos los objetivos completos, se guarda la ruta encontrada
        sem_wait(&mutex); // se espera a que el mutex este disponible para guardar la ruta encontrada
        rutasEncontradas[rutasEncontradasParaSolucion] = *rutaActual; // se guarda la ruta encontrada en el arreglo de rutas encontrada
        rutasEncontradasParaSolucion++; // se incrementa el contador de rutas encontradas
        sem_post(&mutex); // se libera el semaforo para escribir soluciones
        sem_post(&semaforo); // se libera semaforo de la hebra
        return;// si ya se tienen todos los numeros encontrados, se terminara el ciclo o en otro caso cuando ya no queden nodos que recorrer 
    }

    for (i = 0; i < 30; i ++){
        if (grafo[rutaActual->nodoA - 1][i] != -1){
            sem_wait(&semaforo); // se espera a que el semaforo este disponible para guardar la ruta optima
            ruta *rutaNueva;
            *rutaNueva = *rutaActual;
            rutaNueva->nodoA = grafo[rutaActual->nodoA - 1][i] ; // se asigna el nodo a donde se va a llegar
            rutaNueva->cantidadPasosR = rutaActual->cantidadPasosR + 1; // se incrementa la cantidad de pasos en 1
            pthread_t hiloNuevo;
            pthread_create(&hiloNuevo, NULL, (void *)recorridoGrafo,rutaNueva); // se crea un nuevo hilo para recorrer el grafo con la nueva ruta
            pthread_detach(hiloNuevo); // se libera el hilo para volverlo a usar despues
        }
    }
    sem_post(&semaforo); // se libera el semaforo para el siguiente hilo que quiera recorrer el grafo
}












