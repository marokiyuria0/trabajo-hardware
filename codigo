    ruta *rutaInicial;
    rutaInicial = malloc(sizeof(ruta));
    rutaInicial->nodoA = nodoinicial;
    rutaInicial->cantidadPasosR = 0;
    sem_wait(&semaforo); // se espera a que el semaforo este disponible para guardar la ruta optima
    pthread_create(&hiloPrincipal, NULL, (void *)recorridoGrafo,rutaInicial); // se crea el hilo inicial con la ruta inicial

    
    pthread_join(hiloPrincipal, NULL); // se espera a que el hilo principal termine       



    imprime_grafo();

    imprimirTodasLasRutas();

    return 0;
}
