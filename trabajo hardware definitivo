//--------------------RECORRIDOS--------------------------------



void *recorridoGrafo(void *arreglo)
{
    ruta *rutaActual = (ruta *)arreglo;
    int i = 0;
    int k;
    int repetido;



    rutaActual->rutasNodo[rutaActual->cantidadPasosR] = rutaActual->nodoA;
    objetivoMarca(rutaActual->nodoA, rutaActual);

    if (validadorObjetivosCompletados(rutaActual) == 1) {

        sem_wait(&mutex);

        if (rutasEncontradasParaSolucion < 30 && yaExisteRutaConPasos(rutaActual->cantidadPasosR) == 0) {
            rutasEncontradas[rutasEncontradasParaSolucion] = *rutaActual;
            rutasEncontradasParaSolucion++;
        }

        if (rutaActual->cantidadPasosR < mejorCantidadPasos) {
            mejorCantidadPasos = rutaActual->cantidadPasosR;
        }

            printf(".");
            fflush(stdout); // esto se uso para corroborar que el prorama seguia funcionando y no se habia quedado pegado

        sem_post(&mutex);
        sem_post(&semaforo);

        return NULL;
    }

    if (rutaActual->cantidadPasosR >= mejorCantidadPasos) {
        sem_post(&semaforo);
        return NULL;
    }


    for (i = 0; i < 30 && grafo[rutaActual->nodoA - 1][i] != -1; i++) {


        repetido = 0;

        for (k = 0; k <= rutaActual->cantidadPasosR; k++) {
            if (rutaActual->rutasNodo[k] == grafo[rutaActual->nodoA - 1][i]) {
                repetido = 1;
            }
        }

        if (rutaActual->cantidadPasosR < mejorCantidadPasos && repetido == 0) {

            ruta *rutaNueva = malloc(sizeof(ruta));

            if (rutaNueva != NULL) {
                *rutaNueva = *rutaActual;

                rutaNueva->nodoA = grafo[rutaActual->nodoA - 1][i];
                rutaNueva->cantidadPasosR = rutaActual->cantidadPasosR + 1;

                sem_wait(&semaforo);

                pthread_t hiloNuevo;
                pthread_create(&hiloNuevo, NULL, recorridoGrafo, rutaNueva); // aca se usa la recursividad con recorridoGrafo

                pthread_join(hiloNuevo, NULL);
            }
        }
    }

    sem_post(&semaforo);
    return NULL;
}








//-----------------------------------------------------



int main()
{
    pthread_t hiloPrincipal; 
    int i, j;

    lee_grafo();	

    for (i = 0; i < 30; i++){
        rutasEncontradas[i].cantidadPasosR = -1;
    }

    sem_init(&semaforo, 0, 40); // inicializacion del semaforo
    sem_init(&mutex, 0, 1); // inicializacion del mutex

    ruta *rutaInicial;
    rutaInicial = malloc(sizeof(ruta));

    rutaInicial->nodoA = nodoinicial;
    rutaInicial->cantidadPasosR = 0;

    for (i = 0; i < 5; i++){
        rutaInicial->visitado[i] = 0; // se inicializa el arreglo de visitados en 0, es decir, no se ha visitado ningun nodo objetivo
    }

    sem_wait(&semaforo); // se espera a que el semaforo este disponible para guardar la ruta optima

    pthread_create(&hiloPrincipal, NULL, recorridoGrafo, rutaInicial);; // se crea el hilo inicial con la ruta inicial

    pthread_join(hiloPrincipal, NULL); // se espera a que el hilo principal termine       



    imprime_grafo();

    imprimirTodasLasRutas();

    imprimirMejorRuta();

    return 0;
}
